# Ariadne UI — Environment Variables
# Copy this file to .env.local and fill in the values.

# Backend API URL.
# - Development:  http://localhost:8000  (local Python server)
# - Production:   leave EMPTY or omit entirely — the UI is served from the same
#                 Fly.io host as the API, so relative URLs (/analyze, /health)
#                 resolve automatically.
NEXT_PUBLIC_API_URL=http://localhost:8000

# API key for POST /analyze. Must match the API_KEY set on the backend.
# In production (Fly.io), this is baked into the static bundle at Docker build time.
# Pass it as a build arg: fly deploy --build-arg NEXT_PUBLIC_API_KEY=<your-key>
# WARNING: this value is visible in the compiled JS bundle — acceptable for a demo,
# but rotate it if it gets leaked.
NEXT_PUBLIC_API_KEY=
