# flyctl launch added from .gitignore
# ── Secrets & environment ─────────────────────────────────────────────
# .env contains real API keys (OpenAI, Gemini, LangSmith) — never commit
**/.env
**/.env.*
!**/.env.example

# ── Python runtime artifacts ──────────────────────────────────────────
**/__pycache__
**/*.py[cod]
**/*.pyo
**/.pytest_cache
**/.mypy_cache

# ── Virtual environments ──────────────────────────────────────────────
**/.venv
**/venv
**/env

# ── Build & packaging artifacts ───────────────────────────────────────
**/dist
**/build
**/*.egg-info

# ── Eval results (local benchmark artifacts, not source) ──────────────
**/evals/results

# ── Local Qdrant storage volume ───────────────────────────────────────
**/.qdrant

# ── IDE / editor config ──────────────────────────────────────────────
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/*~

# ── OS metadata ───────────────────────────────────────────────────────
**/.DS_Store
**/Thumbs.db

# ── Misc junk files ──────────────────────────────────────────────────
**/=0.8.0

# flyctl launch added from .pytest_cache/.gitignore
# Created by pytest automatically.
.pytest_cache/**/*

# flyctl launch added from .venv/.gitignore
.venv/**/*
fly.toml

# ── Next.js (ui/) ────────────────────────────────────────────────────
# node_modules and build outputs must not be sent to the remote builder.
# The multi-stage Dockerfile installs and builds them from source.
ui/node_modules/**
ui/.next/**
ui/out/**
