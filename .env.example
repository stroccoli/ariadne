OPENAI_API_KEY=
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=ollama
VECTOR_STORE=qdrant

# LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ariadne
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_WORKSPACE_ID=

# Optional model overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=60

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

LOCAL_EMBEDDING_DIMENSIONS=256

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=incident_knowledge
QDRANT_SEARCH_LIMIT=3
QDRANT_CANDIDATE_LIMIT=8
QDRANT_DENSE_WEIGHT=0.65
QDRANT_KEYWORD_WEIGHT=0.35
QDRANT_TIMEOUT_SECONDS=10

API_KEY=

# Redis embedding cache (optional — falls back to uncached when unavailable)
REDIS_URL=redis://localhost:6379/0
EMBEDDING_CACHE_TTL=86400

SENTRY_DSN=

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

LOG_LEVEL=INFO
LOG_FORMAT=text