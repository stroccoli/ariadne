OPENAI_API_KEY=
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=ollama
VECTOR_STORE=qdrant

# LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ariadne
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_WORKSPACE_ID=

# Optional model overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=60

# Gemini (set LLM_PROVIDER=gemini and/or EMBEDDING_PROVIDER=gemini to use)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Retrieval settings
LOCAL_EMBEDDING_DIMENSIONS=256
# Local Qdrant (default)
QDRANT_URL=http://localhost:6333
# Qdrant Cloud: set QDRANT_URL to your cluster URL and provide the API key below
QDRANT_API_KEY=
QDRANT_COLLECTION=incident_knowledge
QDRANT_SEARCH_LIMIT=3
QDRANT_CANDIDATE_LIMIT=8
QDRANT_DENSE_WEIGHT=0.65
QDRANT_KEYWORD_WEIGHT=0.35
QDRANT_TIMEOUT_SECONDS=10

# CORS — comma-separated origins allowed to call the API
# Development default: localhost ports for common frontend dev servers
# Production: set to your deployed frontend URL (e.g. https://ariadne.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text